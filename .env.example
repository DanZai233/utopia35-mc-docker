# Required by Mojang/Minecraft. Set to true only after you accept the EULA.
EULA=false

# Local image name. Use ghcr.io/<github-user-or-org>/utopia35-mc-server for publishing.
IMAGE_NAME=utopia35-mc-server
IMAGE_TAG=local
CONTAINER_NAME=utopia35-mc

# Optional: build from a zip URL instead of local server-files/.
SERVER_PACK_URL=
ALLOW_EMPTY_PACK=false

# Ports
HOST_PORT=25565
SERVER_PORT=25565
RCON_HOST_PORT=25575
RCON_PORT=25575

# JVM
SERVER_JAR=server.jar
MIN_MEMORY=4096M
MAX_MEMORY=4096M
USE_AIKAR_FLAGS=true
JVM_OPTS=
CUSTOM_JVM_ARGS=
CUSTOM_ARGS=
ENABLE_GUI=false

# Minecraft server.properties
MOTD=Utopia 3.5 Fabric Server
LEVEL_NAME=world
LEVEL_SEED=
GAMEMODE=survival
DIFFICULTY=normal
MAX_PLAYERS=20
ONLINE_MODE=true
PVP=true
ALLOW_FLIGHT=true
VIEW_DISTANCE=10
SIMULATION_DISTANCE=10
ENABLE_WHITELIST=false
ENFORCE_WHITELIST=false
ENABLE_COMMAND_BLOCK=false
SPAWN_PROTECTION=16
MAX_TICK_TIME=60000

# RCON is optional. If you enable it, set a strong password.
ENABLE_RCON=false
RCON_PASSWORD=

# Extra server.properties overrides. Use literal "\n" between lines when setting
# from a shell, or edit compose.yaml for long multiline values.
SERVER_PROPERTIES=

# Docker behavior
RESTART_POLICY=unless-stopped
STOP_GRACE_PERIOD=2m

