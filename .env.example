# Required by Mojang/Minecraft. Set to true only after you accept the EULA.
EULA=false

# Published Docker image. You can change this to utopia35-mc-server:local for local-only builds.
IMAGE_NAME=danzai233/utopia35-mc-server
IMAGE_TAG=3.5
CONTAINER_NAME=utopia35-mc

# Optional: build from a zip URL instead of local server-files/.
SERVER_PACK_URL=
ALLOW_EMPTY_PACK=false

# Ports
HOST_PORT=25565
SERVER_PORT=25565
RCON_HOST_PORT=25575
RCON_PORT=25575
BLUEMAP_HOST_PORT=8100
BLUEMAP_PORT=8100

# JVM
SERVER_JAR=server.jar
MIN_MEMORY=4096M
MAX_MEMORY=4096M
USE_AIKAR_FLAGS=true
JVM_OPTS=
CUSTOM_JVM_ARGS=
CUSTOM_ARGS=
ENABLE_GUI=false

# Minecraft server.properties
MOTD=Utopia 3.5 Fabric Server
LEVEL_NAME=world
LEVEL_SEED=
GAMEMODE=survival
DIFFICULTY=normal
MAX_PLAYERS=20
ONLINE_MODE=false
PVP=true
ALLOW_FLIGHT=true
VIEW_DISTANCE=10
SIMULATION_DISTANCE=10
ENABLE_WHITELIST=false
ENFORCE_WHITELIST=false
ENABLE_COMMAND_BLOCK=false
SPAWN_PROTECTION=16
MAX_TICK_TIME=60000

# RCON is optional. If you enable it, set a strong password.
ENABLE_RCON=false
RCON_PASSWORD=

# Extra server.properties overrides. Use literal "\n" between lines when setting
# from a shell, or edit compose.yaml for long multiline values.
SERVER_PROPERTIES=

# Runtime override file. The web panel writes this file inside ./data and the
# Minecraft entrypoint loads it on each container start.
ENV_CONFIG_FILE=/data/server.env

# Docker behavior
RESTART_POLICY=unless-stopped
STOP_GRACE_PERIOD=2m

# Web control panel. It is bound to 127.0.0.1 by default; change PANEL_BIND only
# if you are putting it behind authentication, HTTPS, or a private network.
PANEL_CONTAINER_NAME=utopia35-panel
PANEL_IMAGE_NAME=danzai233/utopia35-mc-panel
PANEL_IMAGE_TAG=latest
PANEL_BIND=127.0.0.1
PANEL_HOST_PORT=8080
PANEL_PASSWORD=change-me
PANEL_RESTART_POLICY=unless-stopped
PANEL_RCON_HOST=minecraft
# Leave empty to load BlueMap through the panel at /bluemap/.
# Set this only if BlueMap has its own public reverse-proxy URL.
BLUEMAP_PUBLIC_URL=
BLUEMAP_INTERNAL_URL=http://minecraft:8100
PLAYER_AUTO_WHITELIST=false

# Optional S3-compatible remote backups. Works with AWS S3, Cloudflare R2,
# MinIO and most S3-compatible object storage providers.
REMOTE_BACKUP_ENABLED=false
REMOTE_BACKUP_ENDPOINT=
REMOTE_BACKUP_REGION=us-east-1
REMOTE_BACKUP_BUCKET=
REMOTE_BACKUP_PREFIX=utopia35
REMOTE_BACKUP_ACCESS_KEY_ID=
REMOTE_BACKUP_SECRET_ACCESS_KEY=
REMOTE_BACKUP_FORCE_PATH_STYLE=true
REMOTE_BACKUP_AUTO_UPLOAD=false
